POSTGRES_DB=ai_car_rental_db
POSTGRES_USER=your_username
POSTGRES_PASSWORD=your_password
POSTGRES_PORT=5432

SPRING_PROFILES_ACTIVE=local
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/ai_car_rental_db
SPRING_DATASOURCE_USERNAME=your_username
SPRING_DATASOURCE_PASSWORD=your_password

JPA_SHOW_SQL=false
JPA_FORMAT_SQL=false
FLYWAY_BASELINE_ON_MIGRATE=false

CORS_ALLOWED_ORIGINS=http://localhost:4200
CUSTOMER_FRONTEND_BASE_URL=http://localhost:4200
STAFF_FRONTEND_BASE_URL=http://localhost:4200

MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_gmail_address@gmail.com
MAIL_PASSWORD=your_gmail_app_password
MAIL_FROM=your_gmail_address@gmail.com
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_SMTP_STARTTLS_REQUIRED=true

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP_ID=ai-car-rental-group
KAFKA_CONSUMER_RETRY_MAX_ATTEMPTS=3
KAFKA_CONSUMER_RETRY_INITIAL_INTERVAL_MS=1000
KAFKA_CONSUMER_RETRY_MULTIPLIER=2.0
KAFKA_CONSUMER_RETRY_MAX_INTERVAL_MS=10000

OUTBOX_PUBLISHER_FIXED_DELAY_MS=10000
OUTBOX_PUBLISHER_MAX_RETRIES=5
OUTBOX_PUBLISHER_BASE_DELAY_SECONDS=10
OUTBOX_PUBLISHER_MAX_DELAY_SECONDS=300
OUTBOX_PUBLISHER_SEND_TIMEOUT_SECONDS=5

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_CACHE_TTL_MS=900000

AI_MARKETPLACE_RATE_LIMIT_MAX_REQUESTS=10
AI_MARKETPLACE_RATE_LIMIT_WINDOW_SECONDS=60

GEMINI_API_KEY=your_gemini_api_key

# Generate a Base64-encoded secret containing at least 32 random bytes.
JWT_SECRET=replace_with_a_secure_base64_secret
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000
AUTH_REFRESH_COOKIE_SECURE=false
AUTH_REFRESH_COOKIE_SAME_SITE=Lax
